---
interface Props { name?: string; url?: string; date?: string }
const { name = '', url = '', date = '' } = Astro.props;
const title = [name, date && `(${date})`].filter(Boolean).join(' ');
---
{url && (
  <a href={url} target="_blank" rel="noopener noreferrer"
     class="ml-1 inline-block align-super text-xs text-sky-600 hover:underline"
     title={title} aria-label={`Source: ${title}`}>&#9432;</a>
)}
